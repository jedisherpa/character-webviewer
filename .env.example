# NewsWiz (Wizard Joe CLI SPA) — live rant/chat/TTS authority.
# Dev: Vite proxies /api → this host (same-origin to Studio).
# Prod: Vercel rewrites /api → this host (see vercel.json).
#
# Local binary without proxy:
#   VITE_NEWSWIZ_URL=http://127.0.0.1:4311
#   VITE_LIVE_API_PROXY=0
#
VITE_NEWSWIZ_URL=https://newswiz.5.78.137.112.sslip.io

# Robin one-bird full SPA for hub card /iframe (/41birdlive).
VITE_BIRD_LIVE_URL=https://41birdlive.5.78.137.112.sslip.io

# 1 = use relative /api (proxy/rewrite). 0 = call NEWSWIZ_URL cross-origin (CORS).
VITE_LIVE_API_PROXY=1

# Optional fleet overrides
# VITE_JOE_NEWSROOM_URL=https://joe-newsroom.5.78.137.112.sslip.io
# VITE_LIVE_API_BASE=
