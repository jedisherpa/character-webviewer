# NewsWiz (Wizard Joe CLI SPA) — same-origin live rant/chat/TTS.
# Character Studio embeds/opens this origin; it does NOT call APIs cross-origin.
#
# Local (newswiz --serve, often :4311 after vite proxy or binary serve):
#   VITE_NEWSWIZ_URL=http://127.0.0.1:4311
#
# Deployed NewsWiz host (not 41BirdLive unless that host IS newswiz):
#   VITE_NEWSWIZ_URL=https://your-newswiz-host.example
#
VITE_NEWSWIZ_URL=

# Optional: Robin one-bird full SPA for hub card /iframe only.
#   VITE_BIRD_LIVE_URL=https://41birdlive.5.78.137.112.sslip.io
VITE_BIRD_LIVE_URL=

# Deprecated: was used for cross-origin liveFetch (removed). Prefer VITE_NEWSWIZ_URL.
# VITE_LIVE_API_BASE=
