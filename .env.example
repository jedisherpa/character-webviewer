# Optional live backend on Hetzner (STT / chat / TTS / dual-view session).
# Visualizers work without this — leave blank for static-only Vercel deploy.
#
# Example:
#   VITE_LIVE_API_BASE=https://prism-gt.example.com
#
# Hetzner must allow CORS from the Vercel origin (see docs/DEPLOY.md).
VITE_LIVE_API_BASE=
