    "smoke:live": "node scripts/smoke-live-integration.mjs",
    "test": "node scripts/prove-parity-contracts.mjs && node scripts/smoke-live-integration.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.0"
