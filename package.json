{
  "name": "character-webviewer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Character Studio webviewer — Wizard Joe (Base 250 + Alpha HD) and Dragonview on Vercel",
  "scripts": {
    "sync-assets": "node scripts/sync-assets.mjs",
    "prebuild": "node scripts/sync-assets.mjs",
    "dev": "vite --host=localhost --port=4400",
    "build": "vite build",
    "preview": "vite preview --host=localhost --port=4401",
